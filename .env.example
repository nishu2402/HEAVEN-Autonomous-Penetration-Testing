# ╔══════════════════════════════════════════════════════════════════╗
# ║  HEAVEN — Environment Configuration Template                     ║
# ║  Copy to .env and fill in real values before starting.           ║
# ║  NEVER commit .env to version control.                           ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Required: Admin credentials ─────────────────────────────────────
# The username you log into the Web UI with (and what the header badge shows).
# Optional — defaults to "admin" if unset.
HEAVEN_ADMIN_USERNAME=admin
# Set a strong password before first run (min 12 chars recommended).
# When this is set, HEAVEN trusts it and skips the forced-password-change prompt.
# When it's blank, HEAVEN seeds admin/admin and forces a change on first login.
HEAVEN_ADMIN_PASSWORD=change_me_before_use

# ─── Database: PostgreSQL (recommended for persistent engagements) ───
# Leave HEAVEN_DB_URL blank to use SQLite offline mode.
HEAVEN_DB_URL=
HEAVEN_DB_HOST=localhost
HEAVEN_DB_PORT=5432
HEAVEN_DB_NAME=heaven
HEAVEN_DB_USER=heaven
HEAVEN_DB_PASSWORD=change_me_before_use

# ─── API server ───────────────────────────────────────────────────────
HEAVEN_API_HOST=127.0.0.1
HEAVEN_API_PORT=8443
# Comma-separated allowed CORS origins (for the React UI in dev)
HEAVEN_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── TLS (production) ─────────────────────────────────────────────────
# Point these at your certificate/key for direct TLS (or use a reverse proxy)
# HEAVEN_TLS_CERT=/etc/ssl/certs/heaven.crt
# HEAVEN_TLS_KEY=/etc/ssl/private/heaven.key

# ─── Optional integrations ────────────────────────────────────────────
# Shodan API key for passive recon
# SHODAN_API_KEY=your_shodan_key_here

# NVD API key (increases rate-limit from 5→50 req/30s)
# NVD_API_KEY=your_nvd_key_here

# Webhook URL for alert notifications (Slack, Teams, custom)
# WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── AI layers (LLM) — all optional; HEAVEN runs fully without them ────
# Pick ONE provider. HEAVEN auto-detects whichever key is set (Anthropic →
# OpenAI → Gemini), or pin it with HEAVEN_LLM_PROVIDER. Install the SDK:
#   Gemini:    pip install -e ".[gemini]"     free key: https://aistudio.google.com/apikey
#   Anthropic: pip install -e ".[anthropic]"  https://console.anthropic.com
#   OpenAI:    pip install -e ".[openai]"     https://platform.openai.com/api-keys
# GEMINI_API_KEY=your_gemini_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# Optional — force a provider / model (else auto-detected + sensible default):
# HEAVEN_LLM_PROVIDER=gemini
# HEAVEN_LLM_MODEL=gemini-1.5-pro

# ─── Security ─────────────────────────────────────────────────────────
# Set to 1 to disable authentication (CI / local dev only — NEVER in production)
# DISABLE_AUTH=0

# Master password for the encrypted credential vault
# VAULT_MASTER_PASSWORD=change_me

# ─── Debug ────────────────────────────────────────────────────────────
HEAVEN_DEBUG=false
